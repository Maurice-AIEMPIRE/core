## ════════════════════════════════════════════════════════════
##  BRAIN SYSTEM — Zentrale Konfiguration
##  Hier trägst du einmalig deine Tokens ein.
##  Dann einfach:  bash brain-system/start.sh
## ════════════════════════════════════════════════════════════


## ── TELEGRAM ──────────────────────────────────────────────
## Bot-Token von @BotFather
TELEGRAM_BOT_TOKEN=HIER_EINTRAGEN

## Deine persönliche Chat-ID (schreib @userinfobot in Telegram)
TELEGRAM_CHAT_ID=HIER_EINTRAGEN

## Deine Telegram User-ID (gleiche Zahl wie CHAT_ID bei Privatchat)
## Mehrere IDs kommagetrennt: 123456,789012
TELEGRAM_ADMIN_IDS=HIER_EINTRAGEN


## ── AI MODELLE ────────────────────────────────────────────
## Anthropic / Claude
ANTHROPIC_API_KEY=HIER_EINTRAGEN

## OpenAI (optional)
OPENAI_API_KEY=HIER_EINTRAGEN

## Lokales Ollama (wenn du lokal Modelle laufen hast)
OLLAMA_URL=http://localhost:11434


## ── OPTIONALE EINSTELLUNGEN ───────────────────────────────
## Wie oft der Telegram-Bot prüft (Sekunden, Standard: 10)
TELEGRAM_POLL_SLEEP=10

## Max. Nachrichten pro Minute pro User (Standard: 20)
TELEGRAM_RATE_LIMIT=20
