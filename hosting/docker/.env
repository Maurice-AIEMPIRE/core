VERSION=0.4.0

# ============================================================
# CORE MEMORY AGENT - Hetzner Server Konfiguration
# Server IP: DEINE_SERVER_IP_HIER_EINTRAGEN (z.B. 65.21.203.174)
# ============================================================

# --- Datenbank (interner Docker-Container) ---
DB_HOST=postgres
DB_PORT=5432

# POSTGRES
POSTGRES_USER=core_user
POSTGRES_PASSWORD=SICHERES_PASSWORT_HIER_EINTRAGEN
POSTGRES_DB=core

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}?schema=core
DIRECT_URL=${DATABASE_URL}

# --- App-Konfiguration ---
REMIX_APP_PORT=3033
APP_ENV=production
NODE_ENV=${APP_ENV}

# WICHTIG: Trage hier deine Server-IP ein!
CORE_APP_ORIGIN=http://DEINE_SERVER_IP_HIER_EINTRAGEN:3033
API_BASE_URL=${CORE_APP_ORIGIN}
CORE_LOGIN_ORIGIN=http://DEINE_SERVER_IP_HIER_EINTRAGEN:3033

# --- Sicherheits-Secrets (bereits generiert) ---
SESSION_SECRET=a1f3c9e2b8d7f4a6c1e3b5d9f2a4c7e0b3d6f9a1c4e7b0d3f6a9c2e5b8d1f4a7
ENCRYPTION_KEY=c7e2a5f8b1d4e7a0c3f6b9d2e5a8c1f4b7d0e3a6c9f2b5d8e1a4c7f0b3d6e9a2
MAGIC_LINK_SECRET=d9b4f1e6a3c8b5f2e9a6d3b0f7c4e1a8d5b2f9c6e3a0d7b4f1c8e5a2d9b6f3c0

# --- Google OAuth (optional) ---
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# --- Redis (interner Docker-Container) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS_DISABLED=true

# --- Email Login ---
ENABLE_EMAIL_LOGIN=true

# --- Neo4j Graph-Datenbank (interner Docker-Container) ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=d9b4f1e6a3c8b5f2e9a6d3b0f7c4e1a8d5b2f9c6e3a0d7b4f1c8e5a2d9b6f3c0
NEO4J_AUTH=neo4j/d9b4f1e6a3c8b5f2e9a6d3b0f7c4e1a8d5b2f9c6e3a0d7b4f1c8e5a2d9b6f3c0

# --- KI Modelle ---
# WICHTIG: OpenAI API Key eintragen!
OPENAI_API_KEY=DEIN_OPENAI_API_KEY_HIER

# Ollama (läuft bereits auf dem Server - host.docker.internal verbindet zu Host)
OLLAMA_URL=http://host.docker.internal:11434

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MODEL_SIZE=1536
MODEL=gpt-4.1-2025-04-14

MODEL_PROVIDER=vercel-ai
GRAPH_PROVIDER=neo4j
VECTOR_PROVIDER=pgvector

# --- Queue ---
QUEUE_PROVIDER=bullmq

# --- Telemetry (deaktiviert für Self-Host) ---
TELEMETRY_ENABLED=false
TELEMETRY_ANONYMOUS=false
POSTHOG_PROJECT_KEY=

# --- Trigger.dev (optional - für Background Jobs) ---
TRIGGER_PROJECT_ID=
TRIGGER_SECRET_KEY=
API_ORIGIN=${CORE_APP_ORIGIN}

# --- Email (optional) ---
EMAIL_TRANSPORT=
REPLY_TO_EMAIL=
FROM_EMAIL=
RESEND_API_KEY=

# --- Reranking (optional) ---
COHERE_API_KEY=

# ============================================================
# GALAXIA BRAIN — Unified Memory Architecture
# ============================================================

# CORE API Token (aus CORE Web-UI: Settings → API Key)
GALAXIA_BRAIN_URL=http://localhost:3033
GALAXIA_BRAIN_TOKEN=CORE_API_TOKEN_HIER

# Mac Brain Port (iCloud Writer)
MAC_BRAIN_PORT=9001
MAC_BRAIN_URL=http://localhost:9001

# iCloud Drive Pfad auf Mac
MAC_ICLOUD_PATH=/Users/maurice/Library/Mobile Documents/com~apple~CloudDocs

# Galaxia Planet Verzeichnis (LanceDB)
GALAXIA_DIR=/root/galaxia
