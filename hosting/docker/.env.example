VERSION=0.4.0

# Database
DB_HOST=postgres
DB_PORT=5432
POSTGRES_USER=docker
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=core
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}?schema=core
DIRECT_URL=${DATABASE_URL}

# App
REMIX_APP_PORT=3033
APP_ENV=production
NODE_ENV=${APP_ENV}
CORE_APP_ORIGIN=http://localhost:3033
API_BASE_URL=${CORE_APP_ORIGIN}
CORE_LOGIN_ORIGIN=http://localhost:3033

# Secrets — MUST be changed before production!
# Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
MAGIC_LINK_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Google OAuth (optional)
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TLS_DISABLED=true

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME_generate_with_openssl_rand_hex_32
NEO4J_AUTH=neo4j/${NEO4J_PASSWORD}

# AI Models
OPENAI_API_KEY=
OLLAMA_URL=http://localhost:11434
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MODEL_SIZE=1536
MODEL=gpt-4.1-2025-04-14

# Infrastructure
QUEUE_PROVIDER=bullmq
GRAPH_PROVIDER=neo4j
VECTOR_PROVIDER=pgvector
MODEL_PROVIDER=vercel-ai

# Telemetry (set false to disable)
POSTHOG_PROJECT_KEY=
