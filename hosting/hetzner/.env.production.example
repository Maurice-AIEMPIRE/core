# =============================================================================
# CORE - Production Environment Variables for Hetzner
# =============================================================================
# Copy this file to .env.production and fill in your values:
#   cp .env.production.example .env.production
#
# IMPORTANT: Never commit .env.production to git!
# =============================================================================

# ─── Version ─────────────────────────────────────────────────────────────────
VERSION=latest

# ─── Domain & URLs ───────────────────────────────────────────────────────────
# Your domain (must have DNS A record pointing to Hetzner server IP)
DOMAIN=core.yourdomain.com
CORE_APP_ORIGIN=https://core.yourdomain.com
CORE_LOGIN_ORIGIN=https://core.yourdomain.com

# ─── Data Path (Hetzner volume mount) ────────────────────────────────────────
DATA_PATH=/mnt/data

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=core_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_1
POSTGRES_DB=core

# Internal database URLs (don't change host/port - they use Docker networking)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=core
DIRECT_URL=${DATABASE_URL}

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_2

# ─── Neo4j ───────────────────────────────────────────────────────────────────
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME_STRONG_PASSWORD_3

# ─── App Secrets ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
SESSION_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL
MAGIC_LINK_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ─── AI Provider (choose one or more) ───────────────────────────────────────
# OpenAI
OPENAI_API_KEY=sk-...

# Model configuration
MODEL=gpt-4.1-2025-04-14
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MODEL_SIZE=1536
MODEL_PROVIDER=vercel-ai

# Ollama (optional - for self-hosted models)
# OLLAMA_URL=http://ollama:11434

# ─── Authentication ──────────────────────────────────────────────────────────
ENABLE_EMAIL_LOGIN=true

# Google OAuth (optional)
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_TRANSPORT=resend
FROM_EMAIL=noreply@yourdomain.com
REPLY_TO_EMAIL=support@yourdomain.com
RESEND_API_KEY=

# ─── Queue ───────────────────────────────────────────────────────────────────
QUEUE_PROVIDER=bullmq

# ─── Graph & Vector ─────────────────────────────────────────────────────────
GRAPH_PROVIDER=neo4j
VECTOR_PROVIDER=pgvector

# ─── Telemetry (disabled by default for self-hosted) ────────────────────────
TELEMETRY_ENABLED=false
TELEMETRY_ANONYMOUS=true

# ─── Trigger.dev (optional) ─────────────────────────────────────────────────
TRIGGER_PROJECT_ID=
TRIGGER_SECRET_KEY=

# ─── Payments (optional) ────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ─── Monitoring (optional) ──────────────────────────────────────────────────
# Slack/Discord webhook for alerts
WEBHOOK_URL=

# ─── Watchtower (auto-update) ───────────────────────────────────────────────
# Set to false to enable auto-updates (default: monitor only)
WATCHTOWER_MONITOR_ONLY=true

# ─── Let's Encrypt ──────────────────────────────────────────────────────────
LETSENCRYPT_EMAIL=admin@yourdomain.com

# ─── Cohere (optional - for reranking) ──────────────────────────────────────
COHERE_API_KEY=
