# ============================================================
# TELEGRAM MULTI-BOT KONFIGURATION
# ============================================================
# Erstelle Bots bei @BotFather auf Telegram und trage die Tokens ein.
# Jeder Bot nutzt ein anderes AI-Modell.
#
# ANLEITUNG:
# 1. Oeffne Telegram, suche @BotFather
# 2. /newbot -> Name eingeben -> Token kopieren
# 3. Wiederhole fuer jeden Bot
# 4. Kopiere diese Datei: cp .env.example .env
# 5. Trage die Tokens ein
# 6. docker compose up -d
# ============================================================

# Bot 1: Claude Haiku 4.5 (schnell, guenstig)
BOT_1_TOKEN=

# Bot 2: GPT-4o-mini (kreativ, vielseitig)
BOT_2_TOKEN=

# Bot 3: Claude Sonnet 4.6 (intelligent, gruendlich)
BOT_3_TOKEN=

# Bot 4: Llama 3.1 8B (Open Source, lokal, kostenlos)
BOT_4_TOKEN=

# LiteLLM Verbindung (normalerweise nicht aendern)
LITELLM_URL=http://galaxia-litellm:4000
LITELLM_API_KEY=sk-galaxia-local

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
