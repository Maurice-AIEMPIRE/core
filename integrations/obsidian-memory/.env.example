# Obsidian memory system — environment

# Path to the vault root
VAULT=/path/to/ObsidianVault

# Work / personal context for the current briefing run.
# Either "work" or "personal". Briefings filter notes accordingly.
BRIEFING_CONTEXT=work

# Todoist (https://todoist.com/app/settings/integrations/developer)
TODOIST_TOKEN=

# Google Calendar — service account or OAuth refresh token
# Easiest path: use the @core/google-calendar CLI and let it cache creds.
GCAL_CALENDAR_ID=primary

# Telegram bot — create with @BotFather, add bot to a chat, get chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Tickers to track in the finance briefing (comma separated, no spaces)
TICKERS=AAPL,MSFT,NVDA,SPY

# Optional — override briefing time window (hours) for "today" boundaries
TODAY_START=06:00
TODAY_END=22:00
