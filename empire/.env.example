# ============================================
# AI EMPIRE - Environment Configuration
# ============================================
# Copy this to .env and fill in your values
# ============================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here

# --- Anthropic / Claude API ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Redis (internal, no change needed) ---
REDIS_URL=redis://redis:6379/0

# --- iCloud Sync (rclone) ---
ICLOUD_ENABLED=true
ICLOUD_REMOTE_NAME=icloud
ICLOUD_SYNC_PATH=/empire/results/

# --- Dropbox Sync (rclone) - optional ---
DROPBOX_ENABLED=false
DROPBOX_REMOTE_NAME=dropbox

# --- X/Twitter Analysis ---
# No API needed - using yt-dlp + scraping
X_ANALYSIS_ENABLED=true

# --- Server ---
EMPIRE_DATA_DIR=/empire
SERVER_TIMEZONE=Europe/Berlin

# --- Portainer ---
PORTAINER_ADMIN_PASSWORD=changeme
