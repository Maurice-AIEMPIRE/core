# UserAI Empire - Environment Configuration
# ==========================================
# Copy this to .env and fill in your values

# === REQUIRED ===
CLAUDE_API_KEY=your-anthropic-api-key-here
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_ADMIN_CHAT_ID=your-telegram-chat-id-here

# === X/TWITTER API (for analysis engine) ===
X_BEARER_TOKEN=your-x-bearer-token-here
# Optional: for posting/interaction
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# === CLOUD SYNC ===
# rclone remote names (configured via rclone config)
RCLONE_ICLOUD_REMOTE=icloud
RCLONE_DROPBOX_REMOTE=dropbox
RCLONE_SYNC_INTERVAL=300

# === INFRASTRUCTURE ===
EMPIRE_DATA_DIR=/empire
CHROMA_HOST=chromadb
CHROMA_PORT=8000
REDIS_URL=redis://redis:6379

# === OPTIONAL ===
OPENAI_API_KEY=
XAI_API_KEY=
HETZNER_API_TOKEN=
